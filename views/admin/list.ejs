<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>活动管理 - 后台</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% if (locals.synced) { %>
  <div style="background:#E8F5E9;color:#2E7D32;text-align:center;padding:10px;font-size:0.9rem;">✅ 已同步到公网！稍等1-2分钟后生效</div>
  <% } %>
  <div class="container">
    <div class="admin-header">
      <h1>活动管理</h1>
      <div style="display:flex; gap:8px;">
        <a href="/admin/new" class="btn btn-primary">+ 新增活动</a>
        <button class="btn btn-outline btn-sm" onclick="syncToGithub()" style="color:#2E7D32;border-color:#2E7D32;">⟳ 同步到公网</button>
        <a href="/admin/change-password" class="btn btn-outline btn-sm">改密</a>
        <a href="/admin/logout" class="btn btn-outline btn-sm">退出</a>
      </div>
    </div>

    <!-- 搜索 + 筛选工具栏 -->
    <div class="admin-toolbar">
      <input type="text" class="search-box" id="adminSearch" placeholder="搜索活动名称..." autocomplete="off">
    </div>

    <div class="filter-bar" id="adminFilterBar">
      <button class="filter-tag active" data-status="all">全部</button>
      <button class="filter-tag" data-status="active">进行中</button>
      <button class="filter-tag" data-status="upcoming">待开始</button>
      <button class="filter-tag" data-status="prize">可兑奖</button>
      <button class="filter-tag" data-status="ended">已结束</button>
    </div>

    <!-- 活动表格 -->
    <div class="table-wrapper">
      <table class="admin-table" id="adminTable">
        <thead>
          <tr>
            <th>活动名称</th>
            <th>状态</th>
            <th>活动时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% activities.forEach(function(act) {
            let timeDisplay = '';
            if (act.isLongTerm) {
              timeDisplay = '长期活动';
            } else {
              // 格式化日期时间显示
              function fmtDateTime(str) {
                if (!str) return '?';
                if (str.includes('T')) {
                  // 精确到时分: 2026-06-14T15:30 -> 06.14 15:30
                  var parts = str.split('T');
                  return parts[0].replace(/-/g, '.') + ' ' + parts[1];
                }
                return str.replace(/-/g, '.');
              }
              timeDisplay = fmtDateTime(act.activityStartDate) + ' ~ ' + fmtDateTime(act.activityEndDate);
            }

            let statusClass = '';
            if (act._status === '进行中') statusClass = 'active-tag';
            else if (act._status === '待开始') statusClass = 'upcoming-tag';
            else if (act._status === '可兑奖') statusClass = 'prize-tag';
            else statusClass = 'ended-tag';

            let dataStatus = '';
            if (act._status === '进行中') dataStatus = 'active';
            else if (act._status === '待开始') dataStatus = 'upcoming';
            else if (act._status === '可兑奖') dataStatus = 'prize';
            else dataStatus = 'ended';
          %>
          <tr class="admin-row" data-name="<%= act.name %>" data-status="<%= dataStatus %>">
            <td><strong><%= act.name %></strong></td>
            <td><span class="status-tag <%= statusClass %>"><%= act._status %></span></td>
            <td class="time-cell"><%= timeDisplay %></td>
            <td class="actions">
              <a href="/admin/edit/<%= act.id %>" class="btn btn-outline btn-sm">编辑</a>
              <button class="btn btn-outline btn-sm" onclick="copyActivity('<%= act.id %>')" style="color:#1976D2;border-color:#1976D2;">复制</button>
              <button class="btn btn-danger btn-sm" onclick="deleteActivity('<%= act.id %>', '<%- act.name %>')">删除</button>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <% if (activities.length === 0) { %>
    <div style="text-align:center; padding:40px 0; color:#999;">
      <p>暂无活动，点击上方按钮新增</p>
    </div>
    <% } %>

    <div style="margin-top: 16px; text-align: center;">
      <a href="/" target="_blank" class="btn btn-outline btn-sm">预览前台 →</a>
    </div>
  </div>

  <script>
    function syncToGithub() {
      if (!confirm('确定要同步活动数据到公网吗？\n\n公网地址: https://sierragao.github.io/xc-activityboard/')) return;
      var btn = event.target;
      btn.textContent = '⟳ 同步中...';
      btn.disabled = true;
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/admin/sync';
      document.body.appendChild(form);
      form.submit();
    }

    // 后台搜索 + 筛选
    let adminKeyword = '';
    let adminFilter = 'all';

    function refreshAdminTable() {
      const rows = document.querySelectorAll('.admin-row');
      rows.forEach(row => {
        const name = row.dataset.name || '';
        const status = row.dataset.status || '';
        const matchSearch = !adminKeyword || name.toLowerCase().includes(adminKeyword);
        const matchFilter = adminFilter === 'all' || status === adminFilter;
        row.style.display = (matchSearch && matchFilter) ? '' : 'none';
      });
    }

    document.getElementById('adminSearch').addEventListener('input', function() {
      adminKeyword = this.value.trim().toLowerCase();
      refreshAdminTable();
    });

    document.querySelectorAll('#adminFilterBar .filter-tag').forEach(tag => {
      tag.addEventListener('click', function() {
        document.querySelectorAll('#adminFilterBar .filter-tag').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        adminFilter = this.dataset.status;
        refreshAdminTable();
      });
    });

    function copyActivity(id) {
      if (confirm('确定要复制该活动吗？')) {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/copy/' + id;
        document.body.appendChild(form);
        form.submit();
      }
    }

    function deleteActivity(id, name) {
      if (confirm('确定要删除活动「' + name + '」吗？\n\n此操作不可恢复。')) {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/delete/' + id;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
</body>
</html>
